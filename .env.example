# ─── TypeFlow Environment Configuration ───────────────────────────────────────
# Copy this file to server/.env and fill in your values.
# NEVER commit server/.env to version control.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Local example: postgresql://postgres:yourpassword@localhost:5432/typeflow
# Supabase example: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/typeflow

# ── Admin Credentials ──────────────────────────────────────────────────────────
# These are used to log into the /owner-admin panel.
OWNER_EMAIL=admin@example.com
OWNER_PASSWORD=changeme123

# ── Session Security ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_secret_string

# ── Server Ports (optional, defaults shown) ────────────────────────────────────
# PORT=5000       # API server port
# API_PORT=5000   # Client-side proxy target
